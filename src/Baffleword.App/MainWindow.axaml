<Window x:Class="Baffleword.App.MainWindow"
        xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:models="using:Baffleword.Core.Models"
        Title="Baffleword"
        Icon="/Assets/Icons/app_icon.ico"
        Width="900"
        Height="700"
        MinWidth="800"
        MinHeight="600"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource PageBackgroundGradient}">
  <Grid>
    <ContentControl x:Name="ContentArea" />

    <ItemsControl x:Name="ToastContainer"
                  HorizontalAlignment="Right"
                  VerticalAlignment="Bottom"
                  Margin="0,0,16,16"
                  IsHitTestVisible="False">
      <ItemsControl.ItemTemplate>
        <DataTemplate x:DataType="models:Achievement">
          <Border Classes="toast" MaxWidth="360">
            <StackPanel Orientation="Horizontal">
              <TextBlock Text="&#x1F3C6;"
                         FontSize="20"
                         VerticalAlignment="Center"
                         Margin="0,0,8,0" />
              <StackPanel>
                <TextBlock Text="{Binding Name}"
                           FontWeight="Bold"
                           Foreground="{StaticResource Gray900Brush}" />
                <TextBlock Text="{Binding Description}"
                           FontSize="12"
                           Foreground="{StaticResource Gray700Brush}"
                           TextWrapping="Wrap" />
              </StackPanel>
            </StackPanel>
          </Border>
        </DataTemplate>
      </ItemsControl.ItemTemplate>
    </ItemsControl>
  </Grid>
</Window>
