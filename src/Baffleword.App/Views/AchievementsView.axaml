<UserControl x:Class="Baffleword.App.Views.AchievementsView"
             xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Baffleword.App.ViewModels"
             xmlns:models="using:Baffleword.Core.Models"
             x:DataType="vm:AchievementsViewModel">
  <Grid Background="{StaticResource PageBackgroundGradient}">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>

    <TextBlock Grid.Row="0"
               Text="Achievements"
               Classes="h1"
               HorizontalAlignment="Center"
               Margin="0,24,0,16" />

    <ScrollViewer Grid.Row="1"
                  VerticalScrollBarVisibility="Auto"
                  Margin="32,0">
      <ItemsControl ItemsSource="{Binding Achievements}">
        <ItemsControl.ItemsPanel>
          <ItemsPanelTemplate>
            <WrapPanel HorizontalAlignment="Center" />
          </ItemsPanelTemplate>
        </ItemsControl.ItemsPanel>
        <ItemsControl.ItemTemplate>
          <DataTemplate x:DataType="models:Achievement">
            <Border Width="200"
                    Margin="8"
                    Classes="achievement-card"
                    Classes.unlocked="{Binding IsUnlocked}">
              <StackPanel>
                <TextBlock Text="{Binding Name}"
                           Classes="h2"
                           FontSize="16"
                           Margin="0,0,0,4"
                           HorizontalAlignment="Center"
                           TextAlignment="Center" />
                <TextBlock Text="{Binding Description}"
                           Classes="caption"
                           TextWrapping="Wrap"
                           Margin="0,0,0,8"
                           HorizontalAlignment="Center"
                           TextAlignment="Center" />
                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Center"
                            IsVisible="{Binding !IsUnlocked}">
                  <Viewbox Width="14" Height="14" Margin="0,0,4,0">
                    <Canvas Width="48" Height="48">
                      <Path Fill="{StaticResource Gray500Brush}" Data="M44,37H4v5c0,1.105,0.895,2,2,2h36c1.105,0,2-0.895,2-2V37z" />
                      <Path Fill="{StaticResource Gray500Brush}" Data="M11,13v3h4v-3c0-4.971,4.029-9,9-9h0c4.971,0,9,4.029,9,9v3h4v-3c0-7.18-5.82-13-13-13h0C16.82,0,11,5.82,11,13z" />
                      <Path Fill="{StaticResource Gray500Brush}" Data="M44,23H4v-5c0-1.105,0.895-2,2-2h36c1.105,0,2,0.895,2,2V23z" />
                      <Rectangle Canvas.Left="4" Canvas.Top="23" Width="40" Height="7" Fill="{StaticResource Gray500Brush}" />
                      <Rectangle Canvas.Left="4" Canvas.Top="30" Width="40" Height="7" Fill="{StaticResource Gray500Brush}" />
                      <Path Fill="{StaticResource Gray700Brush}" Data="M27,29c0-1.657-1.343-3-3-3s-3,1.343-3,3c0,1.304,0.837,2.403,2,2.816V35c0,0.552,0.448,1,1,1s1-0.448,1-1v-3.184C26.163,31.403,27,30.304,27,29z" />
                    </Canvas>
                  </Viewbox>
                  <TextBlock Text="Locked"
                             Classes="caption"
                             Foreground="{StaticResource Gray500Brush}" />
                </StackPanel>
                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Center"
                            IsVisible="{Binding IsUnlocked}">
                  <Viewbox Width="14" Height="14" Margin="0,0,4,0">
                    <Canvas Width="48" Height="48">
                      <Path Fill="{StaticResource SuccessGreenBrush}" Data="M16.599,41.42L1.58,26.401c-0.774-0.774-0.774-2.028,0-2.802l4.019-4.019c0.774-0.774,2.028-0.774,2.802,0L23.42,34.599c0.774,0.774,0.774,2.028,0,2.802l-4.019,4.019C18.627,42.193,17.373,42.193,16.599,41.42z" />
                      <Path Fill="{StaticResource SuccessGreenBrush}" Data="M12.58,34.599L39.599,7.58c0.774-0.774,2.028-0.774,2.802,0l4.019,4.019c0.774,0.774,0.774,2.028,0,2.802L19.401,41.42c-0.774,0.774-2.028,0.774-2.802,0l-4.019-4.019C11.807,36.627,11.807,35.373,12.58,34.599z" />
                    </Canvas>
                  </Viewbox>
                  <TextBlock Text="Unlocked"
                             Foreground="{StaticResource SuccessGreenBrush}"
                             FontSize="12" />
                </StackPanel>
              </StackPanel>
            </Border>
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>
    </ScrollViewer>

    <Button Grid.Row="2"
            Content="Back to Menu"
            Command="{Binding BackCommand}"
            Classes="secondary"
            HorizontalAlignment="Center"
            Margin="0,16,0,24" />
  </Grid>
</UserControl>
