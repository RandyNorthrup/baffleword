<UserControl x:Class="Baffleword.App.Views.HowToPlayView"
             xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Baffleword.App.ViewModels"
             x:DataType="vm:HowToPlayViewModel">
  <Grid Background="{StaticResource PageBackgroundGradient}">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>

    <TextBlock Grid.Row="0"
               Text="How to Play"
               Classes="h1"
               HorizontalAlignment="Center"
               Margin="0,24,0,16" />

    <Border Grid.Row="1"
            Classes="card"
            Margin="64,0">
      <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel>
          <TextBlock Classes="h2" FontSize="18" Text="Objective" Margin="0,0,0,8" />
          <TextBlock Classes="body" TextWrapping="Wrap" Margin="0,0,0,16"
                     Text="Find as many words as possible on the letter grid before time runs out. Words are formed by connecting adjacent letters (horizontally, vertically, or diagonally)." />

          <TextBlock Classes="h2" FontSize="18" Text="Game Modes" Margin="0,0,0,8" />
          <TextBlock Classes="body" TextWrapping="Wrap" Margin="0,0,0,4"
                     Text="- Standard -- 4x4 grid, minimum 3-letter words, 3-minute timer" />
          <TextBlock Classes="body" TextWrapping="Wrap" Margin="0,0,0,4"
                     Text="- Big Board -- 5x5 grid, minimum 4-letter words, 3-minute timer" />
          <TextBlock Classes="body" TextWrapping="Wrap" Margin="0,0,0,16"
                     Text="- Super Board -- 6x6 grid, minimum 4-letter words, 4-minute timer. Includes two-letter combo dice and blocked positions." />

          <TextBlock Classes="h2" FontSize="18" Text="Rules" Margin="0,0,0,8" />
          <TextBlock Classes="body" TextWrapping="Wrap" Margin="0,0,0,4" Text="- Each letter tile can only be used once per word" />
          <TextBlock Classes="body" TextWrapping="Wrap" Margin="0,0,0,4" Text="- Letters must be adjacent (including diagonals)" />
          <TextBlock Classes="body" TextWrapping="Wrap" Margin="0,0,0,4" Text="- Words must be in the dictionary" />
          <TextBlock Classes="body" TextWrapping="Wrap" Margin="0,0,0,4" Text="- 'Qu' counts as a single tile" />
          <TextBlock Classes="body" TextWrapping="Wrap" Margin="0,0,0,16" Text="- No proper nouns, abbreviations, or hyphenated words" />

          <TextBlock Classes="h2" FontSize="18" Text="Scoring -- Standard &amp; Big Board" Margin="0,0,0,8" />
          <TextBlock Classes="body" TextWrapping="Wrap" Margin="0,0,0,4" Text="- 3-4 letters: 1 point" />
          <TextBlock Classes="body" TextWrapping="Wrap" Margin="0,0,0,4" Text="- 5 letters: 2 points" />
          <TextBlock Classes="body" TextWrapping="Wrap" Margin="0,0,0,4" Text="- 6 letters: 3 points" />
          <TextBlock Classes="body" TextWrapping="Wrap" Margin="0,0,0,4" Text="- 7 letters: 5 points" />
          <TextBlock Classes="body" TextWrapping="Wrap" Margin="0,0,0,16" Text="- 8+ letters: 11 points" />

          <TextBlock Classes="h2" FontSize="18" Text="Scoring -- Super Board" Margin="0,0,0,8" />
          <TextBlock Classes="body" TextWrapping="Wrap" Margin="0,0,0,4" Text="- 4 letters: 1 point" />
          <TextBlock Classes="body" TextWrapping="Wrap" Margin="0,0,0,4" Text="- 5 letters: 2 points" />
          <TextBlock Classes="body" TextWrapping="Wrap" Margin="0,0,0,4" Text="- 6 letters: 3 points" />
          <TextBlock Classes="body" TextWrapping="Wrap" Margin="0,0,0,4" Text="- 7 letters: 5 points" />
          <TextBlock Classes="body" TextWrapping="Wrap" Margin="0,0,0,4" Text="- 8 letters: 11 points" />
          <TextBlock Classes="body" TextWrapping="Wrap" Margin="0,0,0,16" Text="- 9+ letters: 2 points per letter" />

          <TextBlock Classes="h2" FontSize="18" Text="Tips" Margin="0,0,0,8" />
          <TextBlock Classes="body" TextWrapping="Wrap" Margin="0,0,0,4" Text="- Look for common prefixes and suffixes (UN-, RE-, -ING, -ED)" />
          <TextBlock Classes="body" TextWrapping="Wrap" Margin="0,0,0,4" Text="- Longer words score exponentially more points" />
          <TextBlock Classes="body" TextWrapping="Wrap" Margin="0,0,0,4" Text="- Bigger boards have more possible words -- explore diagonals!" />
          <TextBlock Classes="body" TextWrapping="Wrap" Text="- Try to find all possible words -- check the results screen to see what you missed!" />
        </StackPanel>
      </ScrollViewer>
    </Border>

    <Button Grid.Row="2"
            Content="Back to Menu"
            Command="{Binding BackCommand}"
            Classes="secondary"
            HorizontalAlignment="Center"
            Margin="0,16,0,24" />
  </Grid>
</UserControl>
