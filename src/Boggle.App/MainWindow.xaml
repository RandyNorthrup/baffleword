<Window x:Class="Boggle.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:Boggle.App.ViewModels"
        xmlns:views="clr-namespace:Boggle.App.Views"
        Title="Boggle"
        Icon="Assets/Icons/app_icon.ico"
        Width="900" Height="700"
        MinWidth="800" MinHeight="600"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource PageBackgroundGradient}">

    <Window.Resources>
        <DataTemplate DataType="{x:Type vm:MainMenuViewModel}">
            <views:MainMenuView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:GameViewModel}">
            <views:GameView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:RoundResultsViewModel}">
            <views:RoundResultsView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:HighScoresViewModel}">
            <views:HighScoresView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:AchievementsViewModel}">
            <views:AchievementsView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:SettingsViewModel}">
            <views:SettingsView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:HowToPlayViewModel}">
            <views:HowToPlayView />
        </DataTemplate>
    </Window.Resources>

    <Grid>
        <ContentControl x:Name="ContentArea" />

        <!-- Achievement Toast Notifications (app-wide, survives view transitions) -->
        <ItemsControl x:Name="ToastContainer" 
                      HorizontalAlignment="Right" VerticalAlignment="Bottom"
                      Margin="0,0,16,16" IsHitTestVisible="False">
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Border Background="{StaticResource GoldBrush}" CornerRadius="8"
                            Padding="12,8" Margin="0,8,0,0" Opacity="0"
                            RenderTransformOrigin="0.5,0.5">
                        <Border.RenderTransform>
                            <TranslateTransform X="300" />
                        </Border.RenderTransform>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#x1F3C6;" FontSize="20" VerticalAlignment="Center"
                                       Margin="0,0,8,0" />
                            <StackPanel>
                                <TextBlock Text="{Binding Name}" FontWeight="Bold"
                                           FontFamily="{StaticResource DefaultFont}"
                                           Foreground="{StaticResource Gray900Brush}" />
                                <TextBlock Text="{Binding Description}" FontSize="12"
                                           FontFamily="{StaticResource DefaultFont}"
                                           Foreground="{StaticResource Gray700Brush}" />
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
    </Grid>
</Window>
