<UserControl x:Class="Boggle.App.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:Boggle.App.Converters">

    <UserControl.Resources>
        <conv:InverseBoolConverter x:Key="InverseBoolConverter" />
    </UserControl.Resources>

    <Grid Background="{StaticResource PageBackgroundGradient}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock Grid.Row="0" Text="Settings" Style="{StaticResource H1Style}"
                   HorizontalAlignment="Center" Margin="0,24,0,16" />

        <!-- Settings Card -->
        <Border Grid.Row="1" Style="{StaticResource CardStyle}" Margin="64,0" VerticalAlignment="Center">
            <StackPanel>
                <!-- SFX Volume -->
                <TextBlock Text="Sound Effects Volume" Style="{StaticResource BodyStyle}" Margin="0,0,0,4" />
                <Slider Minimum="0" Maximum="1" TickFrequency="0.1"
                        Value="{Binding SfxVolume}"
                        IsEnabled="{Binding IsSfxMuted, Converter={StaticResource InverseBoolConverter}}"
                        Style="{StaticResource ThemedSliderStyle}" Margin="0,0,0,4" />
                <CheckBox Content="Mute Sound Effects"
                          IsChecked="{Binding IsSfxMuted}"
                          Style="{StaticResource ThemedCheckBoxStyle}"
                          Margin="0,0,0,20" />

                <!-- Music Volume -->
                <TextBlock Text="Music Volume" Style="{StaticResource BodyStyle}" Margin="0,0,0,4" />
                <Slider Minimum="0" Maximum="1" TickFrequency="0.1"
                        Value="{Binding MusicVolume}"
                        IsEnabled="{Binding IsMusicMuted, Converter={StaticResource InverseBoolConverter}}"
                        Style="{StaticResource ThemedSliderStyle}" Margin="0,0,0,4" />
                <CheckBox Content="Mute Music"
                          IsChecked="{Binding IsMusicMuted}"
                          Style="{StaticResource ThemedCheckBoxStyle}" />
            </StackPanel>
        </Border>

        <!-- Back Button -->
        <Button Grid.Row="2" Content="Back"
                Command="{Binding BackCommand}"
                Style="{StaticResource SecondaryButtonStyle}"
                HorizontalAlignment="Center"
                Margin="0,16,0,24" />
    </Grid>
</UserControl>
