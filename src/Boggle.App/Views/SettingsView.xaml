<UserControl x:Class="Boggle.App.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Background="{StaticResource PageBackgroundGradient}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock Grid.Row="0" Text="Settings" Style="{StaticResource H1Style}"
                   HorizontalAlignment="Center" Margin="0,24,0,16" />

        <!-- Settings Card -->
        <Border Grid.Row="1" Style="{StaticResource CardStyle}" Margin="64,0" VerticalAlignment="Center">
            <StackPanel>
                <!-- Round Timer -->
                <TextBlock Text="Round Timer" Style="{StaticResource BodyStyle}" Margin="0,0,0,8" />
                <UniformGrid Rows="1" Margin="0,0,0,20">
                    <RadioButton Content="1 min" GroupName="Timer"
                                 IsChecked="{Binding IsTimer1Min}"
                                 Style="{StaticResource TimerPresetStyle}"
                                 Margin="0,0,4,0" />
                    <RadioButton Content="3 min" GroupName="Timer"
                                 IsChecked="{Binding IsTimer3Min}"
                                 Style="{StaticResource TimerPresetStyle}"
                                 Margin="4,0,4,0" />
                    <RadioButton Content="5 min" GroupName="Timer"
                                 IsChecked="{Binding IsTimer5Min}"
                                 Style="{StaticResource TimerPresetStyle}"
                                 Margin="4,0,0,0" />
                </UniformGrid>

                <!-- SFX Volume -->
                <TextBlock Text="Sound Effects Volume" Style="{StaticResource BodyStyle}" Margin="0,0,0,4" />
                <Slider Minimum="0" Maximum="1" TickFrequency="0.1"
                        Value="{Binding SfxVolume}" Margin="0,0,0,20" />

                <!-- Music Volume -->
                <TextBlock Text="Music Volume" Style="{StaticResource BodyStyle}" Margin="0,0,0,4" />
                <Slider Minimum="0" Maximum="1" TickFrequency="0.1"
                        Value="{Binding MusicVolume}" Margin="0,0,0,20" />

                <!-- Save Button -->
                <Button Content="Save Settings" Command="{Binding SaveCommand}"
                        Style="{StaticResource PrimaryButtonStyle}" HorizontalAlignment="Center"
                        Margin="0,8,0,0" />
            </StackPanel>
        </Border>

        <!-- Back Button -->
        <Button Grid.Row="2" Content="Back to Menu"
                Command="{Binding BackCommand}"
                Style="{StaticResource SecondaryButtonStyle}"
                HorizontalAlignment="Center"
                Margin="0,16,0,24" />
    </Grid>
</UserControl>
