<UserControl x:Class="Boggle.App.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Background="{StaticResource PageBackgroundGradient}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock Grid.Row="0" Text="Settings" Style="{StaticResource H1Style}"
                   HorizontalAlignment="Center" Margin="0,24,0,16" />

        <!-- Settings Card -->
        <Border Grid.Row="1" Style="{StaticResource CardStyle}" Margin="64,0" VerticalAlignment="Center">
            <StackPanel>
                <!-- Timer Duration -->
                <TextBlock Text="Round Timer (seconds)" Style="{StaticResource BodyStyle}" Margin="0,0,0,4" />
                <Grid Margin="0,0,0,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="60" />
                    </Grid.ColumnDefinitions>
                    <Slider Grid.Column="0" Minimum="60" Maximum="600" TickFrequency="30" IsSnapToTickEnabled="True"
                            Value="{Binding TimerDurationSeconds}" VerticalAlignment="Center" />
                    <TextBlock Grid.Column="1" Text="{Binding TimerDurationSeconds}" Style="{StaticResource ScoreStyle}"
                               FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center" />
                </Grid>

                <!-- Min Word Length -->
                <TextBlock Text="Minimum Word Length" Style="{StaticResource BodyStyle}" Margin="0,0,0,4" />
                <Grid Margin="0,0,0,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="60" />
                    </Grid.ColumnDefinitions>
                    <Slider Grid.Column="0" Minimum="3" Maximum="5" TickFrequency="1" IsSnapToTickEnabled="True"
                            Value="{Binding MinWordLength}" VerticalAlignment="Center" />
                    <TextBlock Grid.Column="1" Text="{Binding MinWordLength}" Style="{StaticResource ScoreStyle}"
                               FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center" />
                </Grid>

                <!-- SFX Volume -->
                <TextBlock Text="Sound Effects Volume" Style="{StaticResource BodyStyle}" Margin="0,0,0,4" />
                <Slider Minimum="0" Maximum="1" TickFrequency="0.1"
                        Value="{Binding SfxVolume}" Margin="0,0,0,20" />

                <!-- Music Volume -->
                <TextBlock Text="Music Volume" Style="{StaticResource BodyStyle}" Margin="0,0,0,4" />
                <Slider Minimum="0" Maximum="1" TickFrequency="0.1"
                        Value="{Binding MusicVolume}" Margin="0,0,0,20" />

                <!-- Save Button -->
                <Button Content="Save Settings" Command="{Binding SaveCommand}"
                        Style="{StaticResource PrimaryButtonStyle}" HorizontalAlignment="Center"
                        Margin="0,8,0,0" />
            </StackPanel>
        </Border>

        <!-- Back Button -->
        <Button Grid.Row="2" Content="Back to Menu"
                Command="{Binding BackCommand}"
                Style="{StaticResource SecondaryButtonStyle}"
                HorizontalAlignment="Center"
                Margin="0,16,0,24" />
    </Grid>
</UserControl>
