<UserControl x:Class="Boggle.App.Views.HighScoresView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Background="{StaticResource PageBackgroundGradient}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="32,24,32,0">
            <TextBlock Text="High Scores" Style="{StaticResource H1Style}"
                       HorizontalAlignment="Center" Margin="0,0,0,16" />

            <!-- Mode Tabs -->
            <UniformGrid Rows="1" HorizontalAlignment="Center" Width="400" Margin="0,0,0,8">
                <Button Content="Standard" Command="{Binding ShowStandardCommand}"
                        Margin="0,0,4,0">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource SecondaryButtonStyle}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsStandardSelected}" Value="True">
                                    <Setter Property="Background" Value="{StaticResource PrimaryBlueBrush}" />
                                    <Setter Property="Foreground" Value="White" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
                <Button Content="Big Boggle" Command="{Binding ShowBigBoggleCommand}"
                        Margin="4,0,4,0">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource SecondaryButtonStyle}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsBigBoggleSelected}" Value="True">
                                    <Setter Property="Background" Value="{StaticResource PrimaryBlueBrush}" />
                                    <Setter Property="Foreground" Value="White" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
                <Button Content="Super Big" Command="{Binding ShowSuperBigBoggleCommand}"
                        Margin="4,0,0,0">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource SecondaryButtonStyle}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsSuperBigBoggleSelected}" Value="True">
                                    <Setter Property="Background" Value="{StaticResource PrimaryBlueBrush}" />
                                    <Setter Property="Foreground" Value="White" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
            </UniformGrid>
        </StackPanel>

        <!-- Scores Table -->
        <Border Grid.Row="1" Style="{StaticResource CardStyle}" Margin="32,16">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <!-- Column Headers -->
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="60" />
                            <ColumnDefinition Width="80" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="80" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Score" Style="{StaticResource CaptionStyle}" FontWeight="Bold" />
                        <TextBlock Grid.Column="1" Text="Words" Style="{StaticResource CaptionStyle}" FontWeight="Bold" />
                        <TextBlock Grid.Column="2" Text="Longest Word" Style="{StaticResource CaptionStyle}" FontWeight="Bold" />
                        <TextBlock Grid.Column="3" Text="Complete" Style="{StaticResource CaptionStyle}" FontWeight="Bold" />
                        <TextBlock Grid.Column="4" Text="Date" Style="{StaticResource CaptionStyle}" FontWeight="Bold" Margin="0,0,4,0" />
                    </Grid>
                    <Separator Margin="0,0,0,4" />

                    <ItemsControl ItemsSource="{Binding Scores}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="60" />
                                        <ColumnDefinition Width="80" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="80" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{Binding Score}"
                                               Style="{StaticResource ScoreStyle}" FontSize="18" />
                                    <TextBlock Grid.Column="1"
                                               Text="{Binding WordsFound}"
                                               Style="{StaticResource BodyStyle}" VerticalAlignment="Center" />
                                    <TextBlock Grid.Column="2" Text="{Binding LongestWord}"
                                               Style="{StaticResource BodyStyle}" VerticalAlignment="Center"
                                               FontWeight="SemiBold" Foreground="{StaticResource PrimaryBlueBrush}" />
                                    <TextBlock Grid.Column="3"
                                               Text="{Binding CompletionPercentage, StringFormat='{}{0:F1}%'}"
                                               Style="{StaticResource BodyStyle}" VerticalAlignment="Center" />
                                    <TextBlock Grid.Column="4"
                                               Text="{Binding AchievedAt, StringFormat='{}{0:MMM dd}'}"
                                               Style="{StaticResource CaptionStyle}" VerticalAlignment="Center" />
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </ScrollViewer>
        </Border>

        <!-- Back Button -->
        <Button Grid.Row="2" Content="Back to Menu"
                Command="{Binding BackCommand}"
                Style="{StaticResource SecondaryButtonStyle}"
                HorizontalAlignment="Center"
                Margin="0,0,0,24" />
    </Grid>
</UserControl>
