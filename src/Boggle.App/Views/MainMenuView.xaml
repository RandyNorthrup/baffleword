<UserControl x:Class="Boggle.App.Views.MainMenuView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Background="{StaticResource PageBackgroundGradient}">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Title Section -->
        <StackPanel Grid.Row="1" HorizontalAlignment="Center" Margin="0,0,0,40">
            <TextBlock Text="BOGGLE"
                       FontSize="56"
                       FontWeight="Bold"
                       FontFamily="{StaticResource DefaultFont}"
                       Foreground="{StaticResource PrimaryBlueBrush}"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,8" />
            <TextBlock Text="Single Player Word Game"
                       Style="{StaticResource BodyStyle}"
                       HorizontalAlignment="Center"
                       Foreground="{StaticResource Gray500Brush}" />
        </StackPanel>

        <!-- Menu Buttons -->
        <StackPanel Grid.Row="2" HorizontalAlignment="Center" Width="280">
            <Button Content="New Game"
                    Command="{Binding NewGameCommand}"
                    Style="{StaticResource PrimaryButtonStyle}"
                    FontSize="16"
                    Padding="24,14"
                    Margin="0,0,0,12" />
            <Button Content="High Scores"
                    Command="{Binding HighScoresCommand}"
                    Style="{StaticResource SecondaryButtonStyle}"
                    Margin="0,0,0,8" />
            <Button Content="Achievements"
                    Command="{Binding AchievementsCommand}"
                    Style="{StaticResource SecondaryButtonStyle}"
                    Margin="0,0,0,8" />
            <Button Content="How to Play"
                    Command="{Binding HowToPlayCommand}"
                    Style="{StaticResource SecondaryButtonStyle}"
                    Margin="0,0,0,8" />
            <Button Content="Settings"
                    Command="{Binding SettingsCommand}"
                    Style="{StaticResource SecondaryButtonStyle}" />
        </StackPanel>

        <!-- Version -->
        <StackPanel Grid.Row="4" HorizontalAlignment="Center" Margin="0,0,0,16">
            <TextBlock Text="v1.0.2"
                       Style="{StaticResource CaptionStyle}"
                       HorizontalAlignment="Center" />
            <TextBlock Text="Randy Northrup"
                       Style="{StaticResource CaptionStyle}"
                       HorizontalAlignment="Center"
                       Margin="0,2,0,0" />
        </StackPanel>
    </Grid>
</UserControl>
