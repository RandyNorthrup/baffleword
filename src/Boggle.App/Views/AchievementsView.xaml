<UserControl x:Class="Boggle.App.Views.AchievementsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:Boggle.App.Converters">

    <UserControl.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVis" />
    </UserControl.Resources>

    <Grid Background="{StaticResource PageBackgroundGradient}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock Grid.Row="0" Text="Achievements" Style="{StaticResource H1Style}"
                   HorizontalAlignment="Center" Margin="0,24,0,16" />

        <!-- Achievement Grid -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="32,0">
            <ItemsControl ItemsSource="{Binding Achievements}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel HorizontalAlignment="Center" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Width="200" Margin="8" CornerRadius="12" Padding="16"
                                Background="{StaticResource WhiteBrush}">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Opacity" Value="0.5" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsUnlocked}" Value="True">
                                            <Setter Property="Opacity" Value="1.0" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <Border.Effect>
                                <DropShadowEffect Color="Black" Opacity="0.06"
                                                  BlurRadius="8" ShadowDepth="2" />
                            </Border.Effect>
                            <StackPanel>
                                <TextBlock Text="{Binding Name}" Style="{StaticResource H2Style}"
                                           FontSize="16" Margin="0,0,0,4" />
                                <TextBlock Text="{Binding Description}" Style="{StaticResource CaptionStyle}"
                                           TextWrapping="Wrap" Margin="0,0,0,8" />
                                <TextBlock Text="🔒 Locked">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock" BasedOn="{StaticResource CaptionStyle}">
                                            <Setter Property="Foreground" Value="{StaticResource Gray500Brush}" />
                                            <Setter Property="Visibility" Value="Visible" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsUnlocked}" Value="True">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                                <TextBlock Text="✅ Unlocked" Foreground="{StaticResource SuccessGreenBrush}"
                                           Visibility="{Binding IsUnlocked, Converter={StaticResource BoolToVis}}"
                                           FontSize="12" />
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- Back Button -->
        <Button Grid.Row="2" Content="Back to Menu"
                Command="{Binding BackCommand}"
                Style="{StaticResource SecondaryButtonStyle}"
                HorizontalAlignment="Center"
                Margin="0,16,0,24" />
    </Grid>
</UserControl>
