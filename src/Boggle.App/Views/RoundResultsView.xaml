<UserControl x:Class="Boggle.App.Views.RoundResultsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Background="{StaticResource PageBackgroundGradient}">
        <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="32">
            <StackPanel HorizontalAlignment="Center" MaxWidth="600">

                <!-- Title -->
                <TextBlock Text="Round Complete!"
                           Style="{StaticResource H1Style}"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,24" />

                <!-- Score Card -->
                <Border x:Name="ScoreCard" Style="{StaticResource CardStyle}" Margin="0,0,0,16"
                        RenderTransformOrigin="0.5,0.5">
                    <Border.RenderTransform>
                        <ScaleTransform ScaleX="1" ScaleY="1" />
                    </Border.RenderTransform>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Column="0" Grid.Row="0" HorizontalAlignment="Center" Margin="0,0,0,16">
                            <TextBlock Text="Score" Style="{StaticResource CaptionStyle}"
                                       HorizontalAlignment="Center" />
                            <TextBlock Text="{Binding Score}" Style="{StaticResource ScoreStyle}"
                                       FontSize="36" HorizontalAlignment="Center" />
                        </StackPanel>

                        <StackPanel Grid.Column="1" Grid.Row="0" HorizontalAlignment="Center" Margin="0,0,0,16">
                            <TextBlock Text="Words Found" Style="{StaticResource CaptionStyle}"
                                       HorizontalAlignment="Center" />
                            <TextBlock Text="{Binding WordsFound}" Style="{StaticResource ScoreStyle}"
                                       FontSize="36" HorizontalAlignment="Center" />
                        </StackPanel>

                        <StackPanel Grid.Column="0" Grid.Row="1" HorizontalAlignment="Center">
                            <TextBlock Text="Completion" Style="{StaticResource CaptionStyle}"
                                       HorizontalAlignment="Center" />
                            <TextBlock Text="{Binding CompletionPercentage, StringFormat={}{0:F1}%}"
                                       Style="{StaticResource ScoreStyle}"
                                       HorizontalAlignment="Center" />
                        </StackPanel>

                        <StackPanel Grid.Column="1" Grid.Row="1" HorizontalAlignment="Center">
                            <TextBlock Text="Longest Word" Style="{StaticResource CaptionStyle}"
                                       HorizontalAlignment="Center" />
                            <TextBlock Text="{Binding LongestWord}" Style="{StaticResource ScoreStyle}"
                                       FontSize="18" HorizontalAlignment="Center" />
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Your Words -->
                <Border Style="{StaticResource CardStyle}" Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="Your Words" Style="{StaticResource H2Style}" Margin="0,0,0,8" />
                        <ItemsControl ItemsSource="{Binding FoundWords}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,2">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{Binding Word}"
                                                   Style="{StaticResource BodyStyle}" />
                                        <TextBlock Grid.Column="1" Text="{Binding Points, StringFormat='+{0}'}"
                                                   Style="{StaticResource BodyStyle}"
                                                   Foreground="{StaticResource SuccessGreenBrush}" />
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <!-- Missed Words -->
                <Expander Header="{Binding TotalPossibleWords, StringFormat='Words You Missed ({0} total possible)'}"
                          Margin="0,0,0,16">
                    <Border Style="{StaticResource CardStyle}">
                        <ItemsControl ItemsSource="{Binding MissedWords}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="{StaticResource Gray100Brush}"
                                            CornerRadius="4" Padding="6,2" Margin="2">
                                        <TextBlock Text="{Binding}" Style="{StaticResource CaptionStyle}" />
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Border>
                </Expander>

                <!-- Action Buttons -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,8,0,0">
                    <Button Content="New Round"
                            Command="{Binding NewRoundCommand}"
                            Style="{StaticResource PrimaryButtonStyle}"
                            Margin="0,0,12,0" />
                    <Button Content="Main Menu"
                            Command="{Binding MainMenuCommand}"
                            Style="{StaticResource SecondaryButtonStyle}" />
                </StackPanel>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
