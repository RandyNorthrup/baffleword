<UserControl x:Class="Boggle.App.Views.GameView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:Boggle.App.Converters">

    <UserControl.Resources>
        <converters:TimeSpanToStringConverter x:Key="TimeSpanToString" />
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
    </UserControl.Resources>

    <Grid Background="{StaticResource PageBackgroundGradient}">
        <!-- Main game content -->
        <Grid x:Name="GameContent">
            <Grid.Style>
                <Style TargetType="Grid">
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsPaused}" Value="True">
                            <Setter Property="Effect">
                                <Setter.Value>
                                    <BlurEffect Radius="20" />
                                </Setter.Value>
                            </Setter>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Grid.Style>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" MaxHeight="250" />
            </Grid.RowDefinitions>

            <!-- Top Bar: Score | Timer | Pause -->
            <Border Grid.Row="0" Style="{StaticResource CardStyle}"
                    Margin="16,16,16,0" Padding="16,12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <!-- Score -->
                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="Score: " Style="{StaticResource BodyStyle}"
                                   VerticalAlignment="Center" />
                        <TextBlock Text="{Binding Score}" Style="{StaticResource ScoreStyle}" />
                    </StackPanel>

                    <!-- Timer -->
                    <TextBlock x:Name="TimerText" Grid.Column="1"
                               Text="{Binding TimeRemaining, Converter={StaticResource TimeSpanToString}}"
                               FontSize="36"
                               RenderTransformOrigin="0.5,0.5">
                        <TextBlock.RenderTransform>
                            <ScaleTransform ScaleX="1" ScaleY="1" />
                        </TextBlock.RenderTransform>
                        <TextBlock.Style>
                            <Style TargetType="TextBlock" BasedOn="{StaticResource TimerStyle}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsTimerWarning}" Value="True">
                                        <Setter Property="Foreground" Value="{StaticResource ErrorRedBrush}" />
                                        <DataTrigger.EnterActions>
                                            <BeginStoryboard x:Name="TimerPulse">
                                                <Storyboard RepeatBehavior="Forever">
                                                    <DoubleAnimation Storyboard.TargetProperty="RenderTransform.ScaleX"
                                                                     From="1.0" To="1.15" Duration="0:0:0.4"
                                                                     AutoReverse="True" />
                                                    <DoubleAnimation Storyboard.TargetProperty="RenderTransform.ScaleY"
                                                                     From="1.0" To="1.15" Duration="0:0:0.4"
                                                                     AutoReverse="True" />
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </DataTrigger.EnterActions>
                                        <DataTrigger.ExitActions>
                                            <StopStoryboard BeginStoryboardName="TimerPulse" />
                                        </DataTrigger.ExitActions>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>

                    <!-- Pause Button -->
                    <Button Grid.Column="2" Content="⏸ Pause"
                            Command="{Binding PauseCommand}"
                            Style="{StaticResource SecondaryButtonStyle}"
                            HorizontalAlignment="Right"
                            Padding="16,8" />
                </Grid>
            </Border>

            <!-- Center: Board Grid -->
            <Border Grid.Row="1" Style="{StaticResource CardStyle}"
                    Margin="16" HorizontalAlignment="Center" VerticalAlignment="Center"
                    Padding="8">
                <ItemsControl x:Name="BoardGrid" ItemsSource="{Binding Tiles}"
                              PreviewMouseLeftButtonDown="BoardGrid_PreviewMouseLeftButtonDown"
                              PreviewMouseMove="BoardGrid_PreviewMouseMove"
                              PreviewMouseLeftButtonUp="BoardGrid_PreviewMouseLeftButtonUp"
                              Background="Transparent">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <UniformGrid Rows="4" Columns="4" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border x:Name="TileBorder" Width="72" Height="72" Margin="4"
                                    BorderThickness="2" CornerRadius="8"
                                    Cursor="Hand"
                                    RenderTransformOrigin="0.5,0.5">
                                <Border.RenderTransform>
                                    <ScaleTransform ScaleX="1" ScaleY="1" />
                                </Border.RenderTransform>
                                <Border.Effect>
                                    <DropShadowEffect Color="Black" Opacity="0.08"
                                                      BlurRadius="8" ShadowDepth="2" />
                                </Border.Effect>
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background" Value="{StaticResource WhiteBrush}" />
                                        <Setter Property="BorderBrush" Value="{StaticResource LightBlueBrush}" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                <Setter Property="Background" Value="{StaticResource PrimaryBlueBrush}" />
                                                <Setter Property="BorderBrush" Value="{StaticResource PrimaryBlueBrush}" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <TextBlock Text="{Binding Letter}"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"
                                           FontFamily="{StaticResource DefaultFont}"
                                           FontSize="24" FontWeight="Bold">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="{StaticResource Gray700Brush}" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                    <Setter Property="Foreground" Value="White" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Border>

            <!-- Bottom: Current Selection + Found Words -->
            <Grid Grid.Row="2" Margin="16,0,16,16">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- Drag Selection Preview -->
                <TextBlock Grid.Row="0"
                           Text="{Binding CurrentWord}"
                           Style="{StaticResource H2Style}"
                           Foreground="{StaticResource PrimaryBlueBrush}"
                           HorizontalAlignment="Center"
                           MinHeight="28"
                           Margin="0,0,0,8" />

                <!-- Feedback -->
                <TextBlock x:Name="FeedbackText" Grid.Row="1" Text="{Binding LastSubmissionFeedback}"
                           Style="{StaticResource BodyStyle}"
                           FontWeight="SemiBold"
                           RenderTransformOrigin="0.5,0.5"
                           Margin="0,4,0,8">
                    <TextBlock.RenderTransform>
                        <ScaleTransform ScaleX="1" ScaleY="1" />
                    </TextBlock.RenderTransform>
                </TextBlock>

                <!-- Found Words List -->
                <Border Grid.Row="2" Style="{StaticResource CardStyle}"
                        MaxHeight="150" Padding="8">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding GroupedFoundWords}">
                            <ItemsControl.GroupStyle>
                                <GroupStyle>
                                    <GroupStyle.HeaderTemplate>
                                        <DataTemplate>
                                            <Border Background="{StaticResource PrimaryBlueBrush}"
                                                    CornerRadius="4" Padding="8,4" Margin="0,4,0,2">
                                                <TextBlock Foreground="White" FontWeight="SemiBold" FontSize="13">
                                                    <Run Text="{Binding Name, StringFormat='{}{0} Letters', Mode=OneWay}" />
                                                    <Run Text="{Binding ItemCount, StringFormat='({0})', Mode=OneWay}" />
                                                </TextBlock>
                                            </Border>
                                        </DataTemplate>
                                    </GroupStyle.HeaderTemplate>
                                </GroupStyle>
                            </ItemsControl.GroupStyle>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="4,2">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{Binding Word}"
                                                   Style="{StaticResource BodyStyle}" />
                                        <TextBlock Grid.Column="1" Text="{Binding Points, StringFormat='+{0}'}"
                                                   Style="{StaticResource BodyStyle}"
                                                   Foreground="{StaticResource SuccessGreenBrush}" />
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Border>
            </Grid>
        </Grid>

        <!-- Pause Overlay -->
        <Grid Visibility="{Binding IsPaused, Converter={StaticResource BoolToVis}}">
            <Border Background="#4D000000">
                <Border Style="{StaticResource CardStyle}"
                        HorizontalAlignment="Center" VerticalAlignment="Center"
                        Width="300" Padding="32">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="Paused" Style="{StaticResource H1Style}"
                                   HorizontalAlignment="Center" Margin="0,0,0,24" />
                        <Button Content="Resume"
                                Command="{Binding ResumeCommand}"
                                Style="{StaticResource PrimaryButtonStyle}"
                                Margin="0,0,0,12"
                                HorizontalAlignment="Stretch" />
                        <Button Content="Quit to Menu"
                                Command="{Binding QuitCommand}"
                                Style="{StaticResource SecondaryButtonStyle}"
                                HorizontalAlignment="Stretch" />
                    </StackPanel>
                </Border>
            </Border>
        </Grid>
    </Grid>
</UserControl>
