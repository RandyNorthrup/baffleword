<UserControl x:Class="Boggle.App.Views.GameView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:Boggle.App.Converters">

    <UserControl.Resources>
        <converters:TimeSpanToStringConverter x:Key="TimeSpanToString" />
        <converters:DoubleToThicknessConverter x:Key="DoubleToThickness" />
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
    </UserControl.Resources>

    <Grid Background="{StaticResource PageBackgroundGradient}">
        <!-- Main game content -->
        <Grid x:Name="GameContent">
            <Grid.Style>
                <Style TargetType="Grid">
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsPaused}" Value="True">
                            <Setter Property="Effect">
                                <Setter.Value>
                                    <BlurEffect Radius="20" />
                                </Setter.Value>
                            </Setter>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Grid.Style>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Top Bar: Score | Timer | Pause -->
            <Border Grid.Row="0" Style="{StaticResource CardStyle}"
                    Margin="16,16,16,0" Padding="16,12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <!-- Score -->
                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="Score: " Style="{StaticResource BodyStyle}"
                                   VerticalAlignment="Center" />
                        <TextBlock Text="{Binding Score}" Style="{StaticResource ScoreStyle}" />
                    </StackPanel>

                    <!-- Timer -->
                    <TextBlock x:Name="TimerText" Grid.Column="1"
                               Text="{Binding TimeRemaining, Converter={StaticResource TimeSpanToString}}"
                               FontSize="36"
                               RenderTransformOrigin="0.5,0.5">
                        <TextBlock.RenderTransform>
                            <ScaleTransform ScaleX="1" ScaleY="1" />
                        </TextBlock.RenderTransform>
                        <TextBlock.Style>
                            <Style TargetType="TextBlock" BasedOn="{StaticResource TimerStyle}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsTimerWarning}" Value="True">
                                        <Setter Property="Foreground" Value="{StaticResource ErrorRedBrush}" />
                                        <DataTrigger.EnterActions>
                                            <BeginStoryboard x:Name="TimerPulse">
                                                <Storyboard RepeatBehavior="Forever">
                                                    <DoubleAnimation Storyboard.TargetProperty="RenderTransform.ScaleX"
                                                                     From="1.0" To="1.15" Duration="0:0:0.4"
                                                                     AutoReverse="True" />
                                                    <DoubleAnimation Storyboard.TargetProperty="RenderTransform.ScaleY"
                                                                     From="1.0" To="1.15" Duration="0:0:0.4"
                                                                     AutoReverse="True" />
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </DataTrigger.EnterActions>
                                        <DataTrigger.ExitActions>
                                            <StopStoryboard BeginStoryboardName="TimerPulse" />
                                        </DataTrigger.ExitActions>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>

                    <!-- Pause Button -->
                    <Button Grid.Column="2"
                            Command="{Binding PauseCommand}"
                            Style="{StaticResource SecondaryButtonStyle}"
                            HorizontalAlignment="Right"
                            Padding="16,8">
                        <StackPanel Orientation="Horizontal">
                            <Viewbox Width="16" Height="16" Margin="0,0,6,0">
                                <Canvas Width="48" Height="48">
                                    <Path Fill="{StaticResource PrimaryBlueBrush}" Data="M20,24H10V8c0-1.1,0.9-2,2-2h6c1.1,0,2,0.9,2,2V24z"/>
                                    <Path Fill="#3A85C2" Data="M18,42h-6c-1.1,0-2-0.9-2-2V24h10v16C20,41.1,19.1,42,18,42z"/>
                                    <Path Fill="{StaticResource PrimaryBlueBrush}" Data="M38,24H28V8c0-1.1,0.9-2,2-2h6c1.1,0,2,0.9,2,2V24z"/>
                                    <Path Fill="#3A85C2" Data="M36,42h-6c-1.1,0-2-0.9-2-2V24h10v16C38,41.1,37.1,42,36,42z"/>
                                </Canvas>
                            </Viewbox>
                            <TextBlock Text="Pause" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>
                </Grid>
            </Border>

            <!-- Center: Board Grid -->
            <Border Grid.Row="1" Style="{StaticResource CardStyle}"
                    Margin="16,8" HorizontalAlignment="Center" VerticalAlignment="Top"
                    Width="{Binding BoardContainerSize}" Height="{Binding BoardContainerSize}" Padding="8">
                <Grid>
                    <ItemsControl x:Name="BoardGrid" ItemsSource="{Binding Tiles}"
                                  PreviewMouseLeftButtonDown="BoardGrid_PreviewMouseLeftButtonDown"
                                  PreviewMouseMove="BoardGrid_PreviewMouseMove"
                                  PreviewMouseLeftButtonUp="BoardGrid_PreviewMouseLeftButtonUp"
                                  Background="Transparent">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <UniformGrid Rows="{Binding DataContext.BoardRows, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                             Columns="{Binding DataContext.BoardColumns, RelativeSource={RelativeSource AncestorType=ItemsControl}}" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border x:Name="TileBorder"
                                    Width="{Binding DataContext.TileSize, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                    Height="{Binding DataContext.TileSize, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                    Margin="{Binding DataContext.TileMargin, RelativeSource={RelativeSource AncestorType=ItemsControl}, Converter={StaticResource DoubleToThickness}}"
                                    BorderThickness="2" CornerRadius="8"
                                    Cursor="Hand"
                                    RenderTransformOrigin="0.5,0.5">
                                <Border.RenderTransform>
                                    <ScaleTransform ScaleX="1" ScaleY="1" />
                                </Border.RenderTransform>
                                <Border.Effect>
                                    <DropShadowEffect Color="Black" Opacity="0.08"
                                                      BlurRadius="8" ShadowDepth="2" />
                                </Border.Effect>
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background" Value="{StaticResource WhiteBrush}" />
                                        <Setter Property="BorderBrush" Value="{StaticResource LightBlueBrush}" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                <Setter Property="Background" Value="{StaticResource PrimaryBlueBrush}" />
                                                <Setter Property="BorderBrush" Value="{StaticResource PrimaryBlueBrush}" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding IsBlocked}" Value="True">
                                                <Setter Property="Background" Value="{StaticResource LightRedBrush}" />
                                                <Setter Property="BorderBrush" Value="{StaticResource ErrorRedBrush}" />
                                                <Setter Property="Cursor" Value="Arrow" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <Grid>
                                    <TextBlock Text="{Binding Letter}"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"
                                               FontFamily="{StaticResource DefaultFont}"
                                               FontSize="{Binding DataContext.TileFontSize, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                               FontWeight="Bold">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground" Value="{StaticResource Gray700Brush}" />
                                                <Setter Property="Visibility" Value="Visible" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                        <Setter Property="Foreground" Value="White" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding IsBlocked}" Value="True">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                    <!-- icons8 Fluent "Unavailable" prohibitory icon for blocked tiles -->
                                    <Viewbox HorizontalAlignment="Center" VerticalAlignment="Center"
                                             Width="{Binding DataContext.TileFontSize, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                             Height="{Binding DataContext.TileFontSize, RelativeSource={RelativeSource AncestorType=ItemsControl}}">
                                        <Viewbox.Style>
                                            <Style TargetType="Viewbox">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsBlocked}" Value="True">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Viewbox.Style>
                                        <Canvas Width="48" Height="48">
                                            <Path Fill="{StaticResource ErrorRedBrush}" Data="M24,4C12.955,4,4,12.955,4,24s8.955,20,20,20s20-8.955,20-20C44,12.955,35.045,4,24,4z M24,38c-7.732,0-14-6.268-14-14s6.268-14,14-14s14,6.268,14,14S31.732,38,24,38z"/>
                                            <Polygon Fill="{StaticResource ErrorRedBrush}" Points="13.371,38.871 9.129,34.629 34.629,9.129 38.871,13.371"/>
                                        </Canvas>
                                    </Viewbox>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                    <!-- Drag Path Line Overlay -->
                    <Canvas x:Name="DragLineCanvas" IsHitTestVisible="False" />
                </Grid>
            </Border>

            <!-- Bottom: Current Selection + Found Words -->
            <Grid Grid.Row="2" Margin="16,0,16,16">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- Drag Selection Preview -->
                <TextBlock Grid.Row="0"
                           Text="{Binding CurrentWord}"
                           Style="{StaticResource H2Style}"
                           Foreground="{StaticResource PrimaryBlueBrush}"
                           HorizontalAlignment="Center"
                           MinHeight="28"
                           Margin="0,0,0,8" />

                <!-- Feedback -->
                <TextBlock x:Name="FeedbackText" Grid.Row="1" Text="{Binding LastSubmissionFeedback}"
                           Style="{StaticResource BodyStyle}"
                           FontWeight="SemiBold"
                           RenderTransformOrigin="0.5,0.5"
                           Margin="0,4,0,8">
                    <TextBlock.RenderTransform>
                        <ScaleTransform ScaleX="1" ScaleY="1" />
                    </TextBlock.RenderTransform>
                </TextBlock>

                <!-- Found Words List -->
                <Border Grid.Row="2" Style="{StaticResource CardStyle}"
                        MaxHeight="150" Padding="8">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding GroupedFoundWords}">
                            <ItemsControl.GroupStyle>
                                <GroupStyle>
                                    <GroupStyle.HeaderTemplate>
                                        <DataTemplate>
                                            <Border Background="{StaticResource PrimaryBlueBrush}"
                                                    CornerRadius="4" Padding="8,4" Margin="0,4,0,2">
                                                <TextBlock Foreground="White" FontWeight="SemiBold" FontSize="13">
                                                    <Run Text="{Binding Name, StringFormat='{}{0} Letters', Mode=OneWay}" />
                                                    <Run Text="{Binding ItemCount, StringFormat='({0})', Mode=OneWay}" />
                                                </TextBlock>
                                            </Border>
                                        </DataTemplate>
                                    </GroupStyle.HeaderTemplate>
                                </GroupStyle>
                            </ItemsControl.GroupStyle>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="4,2">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{Binding Word}"
                                                   Style="{StaticResource BodyStyle}" />
                                        <TextBlock Grid.Column="1" Text="{Binding Points, StringFormat='+{0}'}"
                                                   Style="{StaticResource BodyStyle}"
                                                   Foreground="{StaticResource SuccessGreenBrush}" />
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Border>
            </Grid>
        </Grid>

        <!-- Pause Overlay -->
        <Grid Visibility="{Binding IsPaused, Converter={StaticResource BoolToVis}}">
            <Border Background="#4D000000">
                <Border Style="{StaticResource CardStyle}"
                        HorizontalAlignment="Center" VerticalAlignment="Center"
                        Width="320" Padding="32">
                    <StackPanel HorizontalAlignment="Stretch">
                        <TextBlock Text="Paused" Style="{StaticResource H1Style}"
                                   HorizontalAlignment="Center" Margin="0,0,0,24" />
                        <Button Content="Resume"
                                Command="{Binding ResumeCommand}"
                                Style="{StaticResource PrimaryButtonStyle}"
                                Margin="0,0,0,12"
                                HorizontalAlignment="Stretch" />
                        <Button Content="Settings"
                                Command="{Binding SettingsCommand}"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Margin="0,0,0,12"
                                HorizontalAlignment="Stretch" />
                        <Button Content="Quit to Menu"
                                Command="{Binding QuitCommand}"
                                Style="{StaticResource SecondaryButtonStyle}"
                                HorizontalAlignment="Stretch" />
                    </StackPanel>
                </Border>
            </Border>
        </Grid>

        <!-- Achievement Toast Notifications -->
        <ItemsControl x:Name="ToastContainer" ItemsSource="{Binding AchievementToasts}"
                      HorizontalAlignment="Right" VerticalAlignment="Top"
                      Margin="0,16,16,0" IsHitTestVisible="False">
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Border Background="{StaticResource GoldBrush}" CornerRadius="8"
                            Padding="12,8" Margin="0,0,0,8" Opacity="0"
                            RenderTransformOrigin="0.5,0.5">
                        <Border.RenderTransform>
                            <TranslateTransform X="300" />
                        </Border.RenderTransform>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#x1F3C6;" FontSize="20" VerticalAlignment="Center"
                                       Margin="0,0,8,0" />
                            <StackPanel>
                                <TextBlock Text="{Binding Name}" FontWeight="Bold"
                                           FontFamily="{StaticResource DefaultFont}"
                                           Foreground="{StaticResource Gray900Brush}" />
                                <TextBlock Text="{Binding Description}" FontSize="12"
                                           FontFamily="{StaticResource DefaultFont}"
                                           Foreground="{StaticResource Gray700Brush}" />
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
    </Grid>
</UserControl>
