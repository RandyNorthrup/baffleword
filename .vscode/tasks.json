{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "build",
      "type": "shell",
      "command": "dotnet build Baffleword.sln --configuration Release --verbosity minimal",
      "problemMatcher": [
        "$msCompile"
      ],
      "group": "build"
    },
    {
      "label": "test",
      "type": "shell",
      "command": "dotnet test Baffleword.sln --configuration Release --no-build --verbosity minimal",
      "problemMatcher": [
        "$msCompile"
      ],
      "group": "test"
    },
    {
      "label": "format-check",
      "type": "shell",
      "command": "dotnet format Baffleword.sln --verify-no-changes --severity warn --no-restore",
      "problemMatcher": [
        "$msCompile"
      ]
    }
  ]
}
